# Orbex API (no trailing slash)
VITE_API_BASE_URL=http://127.0.0.1:5000

# Set to 0/false to skip Socket.IO in the SPA (fewer console errors if the backend WS is down).
# VITE_REALTIME=0

# Optional override for Socket.IO HTTP origin when it differs from VITE_API_BASE_URL (no trailing slash).
# VITE_WS_BASE_URL=http://127.0.0.1:5000

# Optional: absolute origin for customer tracking links in WhatsApp (no trailing slash).
# If unset, links use the current browser origin (same host as this dashboard build).
# VITE_PUBLIC_TRACKING_ORIGIN=https://track.example.com

# Google Maps JavaScript API (delivery zones map picker). Copy to .env.local — do not commit real keys.
# VITE_GOOGLE_MAPS_API_KEY=
